# =========================================
# CREDENZIALI TELEGRAM (OBBLIGATORIO)
# =========================================
# Crea bot con @BotFather su Telegram
# Token: https://core.telegram.org/bots/tutorial#obtain-your-bot-token
TELEGRAM_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghij

# Chat IDs autorizzati (separati da virgola)
# Ottieni il tuo con @userinfobot
TELEGRAM_CHAT_IDS=123456789,987654321

# =========================================
# ANTHROPIC API (per AI - CONSIGLIATO)
# =========================================
# Registrati su https://console.anthropic.com
# Crea API key (gratuita con $5 credits)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =========================================
# MARKETPLACE CREDENTIALS (OPZIONALE)
# =========================================
# eBay: https://developer.ebay.com/
EBAY_TOKEN=your_ebay_token_here

# Depop: https://www.depop.com/developers/
DEPOP_AUTH_TOKEN=your_depop_auth_token

# =========================================
# FEATURE ATTIVE/DISATTIVE
# =========================================
# Riconoscimento automatico marca/modello
ABILITA_RICONOSCIMENTO_PRODOTTO=True

# Traduzione automatica in italiano
ABILITA_TRADUZIONE_AUTOMATICA=True

# Parser query naturale (NLU)
ABILITA_PARSING_QUERY_NATURALE=True

# Espansione multilingua query
ABILITA_ESPANSIONE_MULTILINGUA=True

# Score venditore (0-100)
ABILITA_SCORE_VENDITORE=True

# Stima profitto/ROI
ABILITA_STIMA_PROFITTO=True

# OCR immagini (COSTO: 1 AI call/immagine)
ABILITA_OCR=False

# Analisi difetti avanzata (COSTO: 1 AI call/immagine)
ABILITA_ANALISI_DIFETTI_AVANZATA=False

# Reverse image search (interfaccia, nessun provider)
ABILITA_REVERSE_IMAGE_SEARCH=False

# =========================================
# CONFIGURAZIONE SISTEMA
# =========================================
# Costo forfettario per spedizione/commissioni (%)
MARGINE_COSTI_PERCENTO=12.0

# Giorni di validità attributi nel cache
GIORNI_VALIDITA_ATTRIBUTI=30

# Giorni di validità traduzione nel cache
GIORNI_VALIDITA_TRADUZIONE=90

# Giorni di validità profilo venditore nel cache
GIORNI_VALIDITA_PROFILO_VENDITORE=14

# Lingua di default per UI
LINGUA_DEFAULT=it

# =========================================
# LOOP RICERCA AUTOMATICA
# =========================================
# Frequenza ricerca in minuti
FREQUENZA_RICERCA_MINUTI=30

# Numero annunci da raccogliere per ciclo
LIMITE_ANNUNCI_PER_CICLO=100

# Marketplace da cercare (separati da virgola)
# Opzioni: vinted, ebay, depop, subito
MARKETPLACE_ATTIVI=vinted,ebay,depop,subito

# Keyword ricerca (separati da virgola)
KEYWORD_RICERCA=nike,adidas,jordan,sneaker

# =========================================
# TELEGRAM BOT AVANZATO
# =========================================
# Max lunghezza messaggio Telegram (4096 byte limit)
MAX_TELEGRAM_MESSAGE_LENGTH=3000

# Rate limiting: richieste per utente
TELEGRAM_RATE_LIMIT_REQUESTS=30

# Rate limiting: finestra temporale (secondi)
TELEGRAM_RATE_LIMIT_WINDOW=60

# Tempo di cache per ricerche (secondi)
TELEGRAM_CACHE_TTL=3600

# =========================================
# DASHBOARD WEB
# =========================================
# Host per Flask
FLASK_HOST=0.0.0.0

# Port per Flask
FLASK_PORT=5000

# Debug mode (False in produzione!)
FLASK_DEBUG=False

# =========================================
# DATABASE
# =========================================
# Path al database SQLite
DATABASE_PATH=annunci.db

# Abilita WAL mode per performance
DATABASE_WAL_MODE=True

# =========================================
# LOGGING
# =========================================
# Livello log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# File log
LOG_FILE=priceradar.log

# Massimo size file log (MB)
LOG_MAX_SIZE=10

# Numero backup log
LOG_BACKUP_COUNT=5

# =========================================
# PROXY (opzionale)
# =========================================
# Per evitare ban IP da marketplace
HTTP_PROXY=
HTTPS_PROXY=

# =========================================
# NOTE IMPORTANTI
# =========================================
# 1. Salva come .env nella root del progetto
# 2. Non committare .env su Git! (è nel .gitignore)
# 3. Le feature AI richiedono ANTHROPIC_API_KEY
# 4. TELEGRAM_TOKEN è obbligatorio
# 5. TELEGRAM_CHAT_IDS almeno un ID (il tuo)
# 6. Tutti gli altri campi sono opzionali
