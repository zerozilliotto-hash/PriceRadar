# Copia questo file in ".env" (senza .example) e inserisci le tue credenziali.
# NON committare mai il file ".env" reale su GitHub o condividerlo: contiene
# le tue chiavi private.

# --- Telegram ---
# 1. Apri Telegram, cerca @BotFather, scrivi /newbot e segui le istruzioni
# 2. Copia il token che ti da BotFather
TELEGRAM_BOT_TOKEN=8864092581:AAGqkJ95EvkXX-izuJCzl3JJB0ntyqSTrgA

# 3. Per ottenere il tuo chat_id: scrivi un messaggio al tuo bot, poi visita
#    https://api.telegram.org/bot<IL_TUO_TOKEN>/getUpdates
#    e cerca il campo "chat":{"id": ...}
TELEGRAM_CHAT_ID=6305917525

# --- eBay (opzionale, solo se vuoi cercare anche su eBay) ---
# Registrati su https://developer.ebay.com/ , crea una app, e prendi le chiavi
# dalla sezione "Application Keys" (usa le chiavi di Production, non Sandbox)
EBAY_CLIENT_ID=il-tuo-client-id
EBAY_CLIENT_SECRET=il-tuo-client-secret

# --- Anthropic (opzionale, solo se vuoi le funzioni AI: valutazione
# affidabilità, prezzo suggerito, analisi foto) ---
# Prendi la chiave da https://console.anthropic.com/
ANTHROPIC_API_KEY=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
